{
  "name": "todo-platform",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "TODO monorepo with separate API, public web, admin web, and a future mobile app.",
  "scripts": {
    "dev:api": "npm run dev --workspace @todo/api",
    "dev:web": "npm run dev --workspace @todo/web",
    "dev:admin": "npm run dev --workspace @todo/admin",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace @todo/api",
    "prisma:migrate": "npm run prisma:migrate --workspace @todo/api --",
    "prisma:studio": "npm run prisma:studio --workspace @todo/api",
    "db:seed": "npm run db:seed --workspace @todo/api"
  }
}
